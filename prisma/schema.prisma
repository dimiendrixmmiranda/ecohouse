generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  nome               String
  email              String   @unique
  senha              String
  dataDeNascimento   DateTime
  sexo               String
  imagem             String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}